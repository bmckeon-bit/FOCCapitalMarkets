# Copy to .env for local builds, or set these in Netlify > Site settings > Environment variables.
# Leave the Supabase vars blank to run in local-only mode (data saves per browser, not shared).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Editor passcode. Anyone can VIEW; only someone who enters this can EDIT. Required for shared editing.
VITE_EDITOR_PASSCODE=
